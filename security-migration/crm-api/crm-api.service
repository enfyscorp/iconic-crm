[Unit]
Description=DD Connect Secure CRM API
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/dd-connect-crm-api
EnvironmentFile=/etc/dd-connect-crm-api.env
ExecStart=/usr/bin/node /opt/dd-connect-crm-api/server.mjs
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/tmp

[Install]
WantedBy=multi-user.target

